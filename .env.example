# =============================================
# PROMO ACHADOS BRASIL - Configurações
# =============================================
# Copie este arquivo para .env e preencha os valores

# --- Telegram ---
TELEGRAM_BOT_TOKEN=COLE_SEU_TOKEN_DO_BOTFATHER
TELEGRAM_CHAT_ID=@promoachadosbrasiloficial

# --- Mercado Livre ---
# A API pública não requer autenticação para buscas
# Mas se tiver credenciais de desenvolvedor, cole aqui:
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# --- Shopee Affiliate ---
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=

# --- WhatsApp Business (Meta Cloud API) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Número destinatário no formato E.164 (ex: 5511999998888). Obrigatório p/ enviar.
WHATSAPP_TO=

# --- Instagram (Meta Graph API) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# --- Divulgação ---
# Linktree/landing com teus links (entra no rodapé das mensagens do WhatsApp).
# Deixe vazio para omitir o rodapé.
LINKTREE_URL=

# --- Painel (login) ---
# Deixe PANEL_PASSWORD vazio p/ desativar login (dev local).
# Defina uma senha p/ proteger o painel (obrigatório se hospedar fora do PC).
PANEL_USER=admin
PANEL_PASSWORD=

# --- Configurações do Bot ---
BUSCA_INTERVALO_MINUTOS=60
BUSCA_PALAVRAS_CHAVE=creatina,whey protein,notebook,fone bluetooth
BUSCA_DESCONTO_MINIMO=15
BUSCA_PRECO_MAXIMO=500
PAUSA_ENTRE_POSTS=3

# --- Auto-Post (postagem automática pelo agendador) ---
# AUTO_POST_ENABLED=true faz o bot postar sozinho no Telegram as melhores
# ofertas pendentes que JÁ tenham link de afiliado. Default: desligado.
AUTO_POST_ENABLED=false
AUTO_POST_SCORE_MINIMO=60
AUTO_POST_MAX_POR_CICLO=3

# --- Monitoramento de Recorrentes (alerta de queda de preço) ---
# Quando ligado, rebusca os produtos recorrentes e ALERTA no Telegram quando o
# preço cruza o alvo cadastrado OU bate um novo menor preço histórico. Default OFF.
MONITOR_RECORRENTES_ENABLED=false
MONITOR_RECORRENTES_INTERVALO_MINUTOS=360
