# =============================================
# PROMO ACHADOS BRASIL - Configurações
# =============================================
# Copie este arquivo para .env e preencha os valores

# --- Telegram ---
TELEGRAM_BOT_TOKEN=COLE_SEU_TOKEN_DO_BOTFATHER
TELEGRAM_CHAT_ID=@promoachadosbrasiloficial

# --- Mercado Livre ---
# A API pública não requer autenticação para buscas
# Mas se tiver credenciais de desenvolvedor, cole aqui:
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# --- Shopee Affiliate ---
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=

# --- WhatsApp Business (Meta Cloud API) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Instagram (Meta Graph API) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# --- Configurações do Bot ---
BUSCA_INTERVALO_MINUTOS=60
BUSCA_PALAVRAS_CHAVE=creatina,whey protein,notebook,fone bluetooth
BUSCA_DESCONTO_MINIMO=15
BUSCA_PRECO_MAXIMO=500
PAUSA_ENTRE_POSTS=3

# --- Auto-Post (postagem automática pelo agendador) ---
# AUTO_POST_ENABLED=true faz o bot postar sozinho no Telegram as melhores
# ofertas pendentes que JÁ tenham link de afiliado. Default: desligado.
AUTO_POST_ENABLED=false
AUTO_POST_SCORE_MINIMO=60
AUTO_POST_MAX_POR_CICLO=3
