# =============================================
# PROMO ACHADOS BRASIL - Configurações
# =============================================
# Copie este arquivo para .env e preencha os valores

# --- PostgreSQL (banco principal; migração SQLite -> Postgres) ---
# Sobe o banco local com: docker compose up -d
# Estes valores batem com os defaults do docker-compose.yml (dev local).
POSTGRES_USER=promo
POSTGRES_PASSWORD=promo
POSTGRES_DB=promo_achados
POSTGRES_PORT=5432
# String de conexão usada pelo backend (psycopg/SQLAlchemy).
DATABASE_URL=postgresql://promo:promo@localhost:5432/promo_achados

# --- Telegram ---
TELEGRAM_BOT_TOKEN=COLE_SEU_TOKEN_DO_BOTFATHER
TELEGRAM_CHAT_ID=@promoachadosbrasiloficial

# --- Mercado Livre ---
# A API pública não requer autenticação para buscas
# Mas se tiver credenciais de desenvolvedor, cole aqui:
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# --- Shopee Affiliate ---
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=

# --- WhatsApp Business (Meta Cloud API) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Número destinatário no formato E.164 (ex: 5511999998888). Obrigatório p/ enviar.
WHATSAPP_TO=

# --- Instagram (Meta Graph API) ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# --- Divulgação ---
# Linktree/landing com teus links (entra no rodapé das mensagens do WhatsApp).
# Deixe vazio para omitir o rodapé.
LINKTREE_URL=

# --- Painel (login) ---
# Deixe PANEL_PASSWORD vazio p/ desativar login (dev local).
# Defina uma senha p/ proteger o painel (obrigatório se hospedar fora do PC).
PANEL_USER=admin
PANEL_PASSWORD=

# --- Configurações do Bot ---
BUSCA_INTERVALO_MINUTOS=60
BUSCA_PALAVRAS_CHAVE=creatina,whey protein,notebook,fone bluetooth
BUSCA_DESCONTO_MINIMO=15
BUSCA_PRECO_MAXIMO=500
PAUSA_ENTRE_POSTS=3

# --- Revalidação de preço (re-checa o preço atual antes de postar/copiar) ---
# Evita divulgar preço velho. Bloqueia o post se o preço subiu mais que X%.
REVALIDAR_PRECO_ENABLED=true
REVALIDAR_BLOQUEIO_ALTA_PCT=5

# --- Auto-Post (postagem automática pelo agendador) ---
# AUTO_POST_ENABLED=true faz o bot postar sozinho no Telegram as melhores
# ofertas pendentes que JÁ tenham link de afiliado. Default: desligado.
AUTO_POST_ENABLED=false
AUTO_POST_SCORE_MINIMO=60
AUTO_POST_MAX_POR_CICLO=3

# --- Monitoramento de Recorrentes (alerta de queda de preço) ---
# Quando ligado, rebusca os produtos recorrentes e ALERTA no Telegram quando o
# preço cruza o alvo cadastrado OU bate um novo menor preço histórico. Default OFF.
MONITOR_RECORRENTES_ENABLED=false
MONITOR_RECORRENTES_INTERVALO_MINUTOS=360

# --- Espelho (bot-espelho WhatsApp -> sinal de tendência) ---
# O bot-espelho (pasta bot-espelho/) grava as mensagens dos grupos em
# data/espelho_inbox.jsonl. O agendador lê os produtos novos e busca nas fontes.
ESPELHO_ENABLED=true
# Quantos produtos buscar por ciclo (ML tem rate limit; não exagere).
ESPELHO_MAX_TERMOS=5
# Nomes EXATOS dos grupos a espelhar, separados por vírgula. Vazio = TODOS.
ESPELHO_GRUPOS=Promoçãozinha BE29
# Reencaminhar a msg (sem link) p/ outro WhatsApp (modelo antigo). Default OFF.
ENCAMINHAR_WHATSAPP=false
# Número de destino do reencaminho, formato 55DDDNUMERO@c.us (só se ENCAMINHAR=true).
NUMERO_DESTINO=
